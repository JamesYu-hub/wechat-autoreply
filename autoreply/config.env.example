# Copy this file to autoreply/config.env for local use.
# Do not commit autoreply/config.env.

# Comma-separated WeChat system usernames explicitly allowed for controlled tests.
# Keep empty during normal automatic operation to avoid self-reply loops.
AUTOREPLY_ALLOWED_SYSTEM_USERNAMES=

# Idle polling interval in seconds. Default is 300 seconds.
AUTOREPLY_IDLE_INTERVAL_SECONDS=300

# Cron may wake exactly on the minute; allow slight early wake-up versus saved target.
AUTOREPLY_IDLE_WAKE_EARLY_TOLERANCE_SECONDS=5

# Active polling interval after private-message activity is detected.
AUTOREPLY_ACTIVE_INTERVAL_SECONDS=10

# Return from active mode after this many consecutive empty active polls.
AUTOREPLY_EMPTY_POLLS_TO_IDLE=30

# Local Qwen/OpenAI-compatible API.
AUTOREPLY_AI_BASE_URL=http://127.0.0.1:8080/v1
AUTOREPLY_AI_MODEL=
AUTOREPLY_AI_MAX_HISTORY_TURNS=24
AUTOREPLY_AI_MAX_TOKENS=1024

# Optional overrides.
AUTOREPLY_DB_PATH=autoreply/unread_messages.sqlite3
AUTOREPLY_WECHAT_CLI=wechat-cli
AUTOREPLY_HISTORY_LIMIT=1000
AUTOREPLY_INITIAL_LOOKBACK_SECONDS=600
